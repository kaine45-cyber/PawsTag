# Browser-facing API base URL.
# Keep "/api" to use the Next.js proxy in both local dev and Vercel.
# QUAN TRỌNG: phải giữ same-origin (/api). Trỏ thẳng sang origin backend khác
# domain sẽ làm SameSite=Lax không gửi cookie auth trên XHR → mất session.
NEXT_PUBLIC_API_URL=/api

# Server-side target used by next.config.ts rewrites.
# Local default: http://localhost:8082
# Vercel production: https://your-render-backend.onrender.com
API_PROXY_TARGET=http://localhost:8082

# Reserved for the Goong map step.
NEXT_PUBLIC_GOONG_MAPTILES_KEY=

# Social login — để trống thì nút tương ứng tự ẩn.
# Google: OAuth 2.0 Web Client ID (khớp GOOGLE_CLIENT_ID phía backend)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Facebook: App ID (khớp FACEBOOK_APP_ID phía backend). FB yêu cầu HTTPS khi
# lên production; dev test qua tunnel cloudflared.
NEXT_PUBLIC_FACEBOOK_APP_ID=
