# Local defaults
PORT=8082
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5443/pawstag
SPRING_DATASOURCE_USERNAME=pawstag
SPRING_DATASOURCE_PASSWORD=pawstag

# Production security
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-bytes
JWT_EXPIRATION_MS=86400000
CORS_ORIGINS=http://localhost:3000

# Upload URLs
UPLOAD_DIR=uploads
UPLOAD_BASE_URL=http://localhost:8082/api

# Goong REST API for reverse geocoding scan locations
GEOCODING_ENABLED=true
GOONG_API_URL=https://rsapi.goong.io
GOONG_API_KEY=

# Social login — để trống thì endpoint tương ứng từ chối mọi token (fail-safe)
# Google: OAuth 2.0 Web Client ID (Google Cloud Console)
GOOGLE_CLIENT_ID=
# Facebook: App ID + App Secret (Meta for Developers).
# Lưu ý: FB yêu cầu HTTPS + App Domains khớp khi lên production;
# dev test qua tunnel cloudflared (xem next.config.ts allowedDevOrigins).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Email OTP, optional until forgot-password email delivery is used
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
# Required for forgot-password email. Copying this file alone does not make
# Spring Boot load it; export these variables or configure them in the IDE/host.
MAIL_USERNAME=your-smtp-account@example.com
MAIL_PASSWORD=your-smtp-password-or-app-password
MAIL_FROM=PawsTag <an-authorized-sender@example.com>

# Operational knobs
RATE_LIMIT_PER_MINUTE=100
APP_LOG_LEVEL=INFO
